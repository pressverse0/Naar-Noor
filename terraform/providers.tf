terraform {
  required_version = ">= 1.0"
  required_providers {
    kubernetes = {
      source  = "hashicorp/kubernetes"
      version = "~> 2.20"
    }
    helm = {
      source  = "hashicorp/helm"
      version = "~> 2.10"
    }
  }
}

# Kubernetes Provider
provider "kubernetes" {
  config_path = var.kubernetes_config_path
}

# Helm Provider
provider "helm" {
}
