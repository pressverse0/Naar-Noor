#!/usr/bin/env sh
# Husky pre-commit hook - validates code quality for monorepo
# Runs both backend and frontend tests before allowing commits
# Projects: api-server (backend), naar-noor (frontend)

echo ""
echo "╔════════════════════════════════════════════════════════════════╗"
echo "║         🧪 MONOREPO PRE-COMMIT VALIDATION                      ║"
echo "║     Testing both backend and frontend before commit...         ║"
echo "╚════════════════════════════════════════════════════════════════╝"
echo ""

EXIT_CODE=0

# Function to handle backend tests
run_backend_tests() {
  if [ ! -d "api-server" ]; then
    echo "⚠️  Backend (api-server) directory not found - skipping"
    return 0
  fi

  echo "📦 Backend Tests (C# / .NET)"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  if ! command -v dotnet &> /dev/null; then
    echo "⚠️  dotnet not found - skipping backend tests"
    echo "    Install .NET SDK to enable backend validation"
    echo ""
    return 0
  fi

  (
    cd api-server
    dotnet test --filter "Category=UnitTest" --no-build --verbosity quiet 2>/dev/null
  )

  if [ $? -ne 0 ]; then
    echo "❌ Backend tests FAILED"
    echo ""
    return 1
  else
    echo "✅ Backend tests PASSED"
    echo ""
    return 0
  fi
}

# Function to handle frontend tests
run_frontend_tests() {
  if [ ! -d "naar-noor" ] || [ ! -f "naar-noor/package.json" ]; then
    echo "⚠️  Frontend (naar-noor) directory not found - skipping"
    return 0
  fi

  echo "📱 Frontend Tests (Angular)"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  if ! command -v npm &> /dev/null; then
    echo "❌ npm not found - cannot run frontend tests"
    echo "    Install Node.js and npm to enable frontend validation"
    echo ""
    return 1
  fi

  (
    cd naar-noor
    npm test -- --run 2>/dev/null
  )

  if [ $? -ne 0 ]; then
    echo "❌ Frontend tests FAILED"
    echo ""
    return 1
  else
    echo "✅ Frontend tests PASSED"
    echo ""
    return 0
  fi
}

# Run tests
run_backend_tests
if [ $? -ne 0 ]; then
  EXIT_CODE=1
fi

run_frontend_tests
if [ $? -ne 0 ]; then
  EXIT_CODE=1
fi

# Final status
echo "╔════════════════════════════════════════════════════════════════╗"

if [ $EXIT_CODE -eq 0 ]; then
  echo "║ ✅ ALL TESTS PASSED - Commit proceeding...                     ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""
  exit 0
else
  echo "║ ❌ TESTS FAILED - Commit blocked                               ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Fix the failing tests and try again."
  echo ""
  echo "To bypass this check (NOT RECOMMENDED):"
  echo "  git commit --no-verify"
  echo ""
  exit 1
fi
